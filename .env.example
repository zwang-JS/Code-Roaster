# ===========================================
# Code Roaster 配置文件模板
# 复制此文件为 .env 并填入你的真实 API Key
# ===========================================

# --- 接口类型：openai（兼容接口）或 anthropic（Claude 原生）---
ROASTER_API_TYPE=openai

# --- OpenAI 兼容接口（DeepSeek / OpenAI / 智谱 / Ollama 等）---
ROASTER_BASE_URL=https://api.deepseek.com/v1
ROASTER_API_KEY=your_own_api_key_here
ROASTER_MODEL=deepseek-chat

# --- Anthropic Claude 原生接口（取消注释以使用）---
# ROASTER_API_TYPE=anthropic
# ROASTER_API_KEY=sk-ant-your-anthropic-api-key-here
# ROASTER_MODEL=claude-sonnet-4-6
