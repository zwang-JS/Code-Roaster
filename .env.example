# ===========================================
# Code Roaster 配置文件模板
# 复制此文件为 .env 并填入你的真实 API Key
# ===========================================

# DeepSeek（默认示例）
ROASTER_BASE_URL=https://api.deepseek.com/v1
ROASTER_API_KEY=your_own_api_key_here
ROASTER_MODEL=deepseek-chat

# OpenAI 示例（取消注释以使用）
# ROASTER_BASE_URL=https://api.openai.com/v1
# ROASTER_API_KEY=sk-your-openai-api-key-here
# ROASTER_MODEL=gpt-4o

# 智谱 AI 示例（取消注释以使用）
# ROASTER_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ROASTER_API_KEY=your-zhipu-api-key-here
# ROASTER_MODEL=glm-4-flash
